{
  "name": "feedbackflow-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Automated micro-SaaS to ingest, analyze, and triage public reviews using LLMs.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "seed": "tsx scripts/seed.ts",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "backfill:viewer": "tsx scripts/backfill-viewer-roles.ts",
    "ingest": "tsx scripts/ingest.ts",
    "ingest:lambda": "tsx scripts/build-lambda.ts",
    "digest": "tsx scripts/digest.ts",
    "digest:lambda": "tsx scripts/build-digest-lambda.ts",
    "unsnooze": "tsx scripts/unsnooze.ts",
    "sam:validate": "cd aws && sam validate",
    "sam:build": "cd aws && sam build",
    "sam:deploy": "cd aws && sam deploy --guided",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "@prisma/client": "^5.22.0",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^2.4.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.454.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.10",
    "next-themes": "^0.4.6",
    "openai": "^4.68.0",
    "papaparse": "^5.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "sonner": "^1.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
