# ----------------------------------------------------------------------------
# FeedbackFlow AI - Environment Variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ----------------------------------------------------------------------------

# ---- App ----
# Base URL of the deployed app (used by NextAuth for callbacks).
NEXTAUTH_URL=http://localhost:3000
# Random secret used to sign JWTs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string

# ---- Google OAuth (optional) ----
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Database (Postgres) ----
# Local docker-compose Postgres. In prod, use your RDS endpoint + SecretsManager.
DATABASE_URL=postgresql://feedbackflow:feedbackflow@localhost:5432/feedbackflow?schema=public

# ---- LLM (local Ollama by default, OpenAI fallback) ----
# Provider: "ollama" (default, free, local) or "openai" (cloud, requires API key)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
# qwen2.5:1.5b is better for translation than 0.5b (more accurate, still fast locally)
OLLAMA_MODEL=qwen2.5:1.5b
# OpenAI fallback (only used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-replace-with-real-key
OPENAI_MODEL=gpt-4o-mini

# ---- Data Source: GitHub Issues API ----
# Public repo to monitor for "bug reports", in `owner/repo` form.
GITHUB_REPO=vercel/next.js
# Optional but strongly recommended to avoid 60 req/hr unauthenticated limit.
GITHUB_TOKEN=ghp-replace-with-personal-access-token
# Look back window for the daily ingest (hours).
INGEST_LOOKBACK_HOURS=24
# Max issues to fetch per run (pagination cap).
INGEST_MAX_ITEMS=50

# ---- Bonus: Slack outgoing webhook (severity >= 4) ----
# Leave empty to disable Slack notifications.
SLACK_WEBHOOK_URL=

# ---- Bonus: Email digest (Cron Pattern B) ----
# Leave empty to disable email digest.
# SMTP URL format: smtp(s)://user:pass@host:port
DIGEST_SMTP_URL=
DIGEST_FROM=feedbackflow@example.com
# Recipient address for the daily digest email.
DIGEST_TO=
